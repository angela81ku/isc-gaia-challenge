ROUTINE RunScript
RunScript
 Do Run()
 Quit
Run()
 ; --- timed section: pure data processing only ---
 Set startTime = $ZHOROLOG
 Set gaia = ##class(%SYS.Python).Import("gaia")
 Do gaia."run"()
 Set elapsed = $ZHOROLOG - startTime
 Write "Elapsed time: ", elapsed, " seconds", !
 ; --- bonus: AI summary (outside timing, optional) ---
 Do gaia."ai_summary"()
 Quit
